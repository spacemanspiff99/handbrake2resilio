# handbrake2resilio — environment configuration
# Copy this to .env and fill in values before starting

# ==============================================================
# REQUIRED: JWT Secret Key
# Generate with: openssl rand -base64 32
# Must be at least 16 characters. Container will refuse to start
# without a valid key.
# ==============================================================
JWT_SECRET_KEY=change-me-to-a-random-string

# Database path (shared volume between api-gateway and handbrake-service)
DATABASE_PATH=/app/data/handbrake2resilio.db

# Input media paths (read-only mounts)
INPUT_TV_PATH=/mnt/tv
INPUT_MOVIES_PATH=/mnt/movies

# Output path (where HandBrake writes converted files — Resilio Sync watches this)
OUTPUT_PATH=/mnt/archive/Resilio_sync

# API Gateway port
API_PORT=8080

# HandBrake service port
HANDBRAKE_PORT=8081
