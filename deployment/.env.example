# handbrake2resilio — environment configuration
# Copy to project root: cp deployment/.env.example .env
# Then edit .env with your actual values

# ==============================================================
# REQUIRED: Generate with: openssl rand -base64 32
# Container will refuse to start without a valid key (16+ chars)
# ==============================================================
JWT_SECRET_KEY=change-me-to-a-random-string

# Port mappings (host ports)
API_PORT=8080
HANDBRAKE_PORT=8081
FRONTEND_PORT=7474

# Input media paths (mounted read-only)
INPUT_TV_PATH=/mnt/tv
INPUT_MOVIES_PATH=/mnt/movies

# Output path — Resilio Sync watches this folder (mounted read-write for handbrake-service)
OUTPUT_PATH=/mnt/archive/Resilio_sync

# HandBrake job concurrency
MAX_CONCURRENT_JOBS=2

# CORS origins — use * for home LAN, or comma-separated list e.g. http://192.168.10.18:7474
CORS_ORIGINS=*

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
