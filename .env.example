# handbrake2resilio — copy to `.env` in this directory for `docker compose --env-file .env up`

# REQUIRED: Generate with: openssl rand -base64 32
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-16-chars

# Port mappings (host ports)
API_PORT=8080
HANDBRAKE_PORT=8081
FRONTEND_PORT=7474

# Media paths — point to your actual media directories
MEDIA_INPUT_PATH=/mnt/media/input
MEDIA_OUTPUT_PATH=/mnt/media/output

# HandBrake job concurrency
MAX_CONCURRENT_JOBS=2

# CORS origins — use * for home LAN
CORS_ORIGINS=*

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
